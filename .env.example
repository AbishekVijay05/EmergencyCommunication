# =============================================================================
# Emergency Edge/Fog Communication System — Environment Configuration Template
# Copy to .env and update values for your environment
# =============================================================================

# ---- General ----
COMPOSE_PROJECT_NAME=emergency-edge-system
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- PostgreSQL ----
POSTGRES_USER=emergency_admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=emergency_main

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# ---- Redpanda (Kafka API) ----
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# ---- JWT / Auth ----
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- RSA Keys ----
RSA_KEY_SIZE=2048

# ---- AES Encryption ----
AES_KEY_SIZE=256

# ---- Service Ports ----
GATEWAY_PORT=8000
AUTH_PORT=8001
MESSAGING_PORT=8002
EDGE_PORT=8010
FOG_PORT=8020
EVENTS_PORT=8003
PREDICTION_PORT=8004
DSL_PORT=8005
PROJECT_MGMT_PORT=8006
DASHBOARD_PORT=3000

# ---- Monitoring ----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
